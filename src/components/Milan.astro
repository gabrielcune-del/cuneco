---
// MILAN — featured products preview on home page.
// Shows 4 iconic produse + CTA to full catalog. Real catalog lives at /catalog
import productsData from "../data/products.json";
const featured = productsData.products.filter(p => p.featured);
---

<section id="milan" class="relative paper py-20 lg:py-32 overflow-hidden grain">
  <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
    <!-- Section header -->
    <div class="grid lg:grid-cols-12 gap-6 lg:gap-10 items-end mb-12 lg:mb-20">
      <div class="lg:col-span-7 reveal-up">
        <div class="flex items-center gap-3 mb-4 lg:mb-6">
          <span class="inline-block w-10 h-px bg-brick"></span>
          <span class="eyebrow text-ink/60">Catalog Milan · {productsData.products.length} produse</span>
        </div>
        <h2 class="display-tight text-ink text-[clamp(2.5rem,8vw,6rem)]">
          De la Milan,<br />
          <span class="italic-serif text-brick" style="text-transform: none;">cu drag.</span>
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 reveal-up" style="animation-delay:0.15s">
        <p class="text-ink/70 leading-relaxed">
          Croissants, rulade, napolitane, biscuiți și prăjituri Milan — peste 30 de produse în catalog. Aici sunt cele mai cerute. Restul, în catalogul complet.
        </p>
      </div>
    </div>

    <!-- Featured grid: 4 cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-12 lg:mb-16">
      {featured.map((p, i) => (
        <a
          href={`/catalog#${p.slug}`}
          class="group relative reveal-up flex flex-col bg-cream-dark overflow-hidden border-2 border-transparent hover:border-brick transition-colors"
          style={`animation-delay:${i * 0.08}s`}
        >
          <div class="relative aspect-square overflow-hidden bg-cream">
            <img
              src={p.image}
              alt={p.name}
              class="w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-105"
              width="800" height="800"
              loading="lazy"
              decoding="async"
            />
            <div class={`absolute top-0 left-0 px-2.5 py-1 numeric font-bold text-[10px] tracking-widest text-cream ${i % 2 === 0 ? 'bg-brick' : 'bg-navy'}`}>
              N° {String(i+1).padStart(2,'0')}
            </div>
          </div>
          <div class="p-4 lg:p-5 bg-cream flex flex-col flex-1">
            <div class="eyebrow text-ink/40 text-[10px] mb-1">Milan · {productsData.categories[p.category].label}</div>
            <h3 class="display-tight text-ink text-xl lg:text-2xl mb-2 leading-tight">{p.name}</h3>
            <div class="flex items-center justify-between text-xs mt-auto">
              <span class="numeric text-ink/60">{p.weight}</span>
              <span class="eyebrow text-brick group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA → full catalog -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 pt-8 border-t border-ink/15 reveal-up">
      <div>
        <p class="italic-serif text-2xl lg:text-3xl text-ink/70" style="text-transform: none;">
          Încă <span class="text-brick">{productsData.products.length - featured.length}</span> de produse în catalogul complet.
        </p>
        <p class="text-sm text-ink/50 mt-2">Croissants · Rulade · Napolitane · Biscuiți · Prăjituri · De post · Vrac</p>
      </div>
      <a
        href="/catalog"
        class="btn-magnetic btn-brick group inline-flex items-center gap-3 bg-brick text-cream px-7 py-5 text-sm font-bold uppercase tracking-widest border-2 border-brick"
      >
        <span class="relative z-10">Catalog complet</span>
        <span class="relative z-10 inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
